<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>{{ title | default("Miguel Cotto Promotions | Elite Boxing Events") }}</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#d72323",
                        "background-light": "#f8f6f6",
                        "background-dark": "#120909",
                        "surface": "#201212",
                        "border-muted": "#452626",
                    },
                    fontFamily: {
                        "display": ["Space Grotesk", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "9999px"},
                },
            },
        }
    </script>
    <style>
      .no-scrollbar::-webkit-scrollbar { display: none; } 
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      {{ extra_css | safe }}
    </style>
    {% block head %}{% endblock %}
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display flex flex-col min-h-screen">

    <!-- Top Navigation -->
    <header class="sticky top-0 z-50 w-full border-b border-border-muted bg-background-dark/95 backdrop-blur-md px-6 md:px-12 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a class="flex items-center" href="/">
                    <img src="/assets/logo.svg" alt="Miguel Cotto Promotions Logo" class="h-[58px] md:h-[69px] w-auto object-contain" />
                </a>
                <nav class="hidden lg:flex items-center gap-6">
                    <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase {% if '/events' in page.url %}text-primary{% endif %}" href="/events.html">Events</a>
                    <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase {% if '/boxers' in page.url or '/profile' in page.url %}text-primary{% endif %}" href="/boxers.html">Boxers</a>
                    <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase {% if '/news' in page.url %}text-primary{% endif %}" href="/news.html">News</a>
                    <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase" href="/#videos">Videos</a>
                    <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase {% if '/about' in page.url %}text-primary{% endif %}" href="/about.html">About Us</a>
                </nav>
            </div>
            <div class="flex items-center gap-4">
                <button class="bg-primary hover:bg-red-700 text-white text-xs font-bold py-2.5 px-6 rounded transition-all uppercase tracking-wider" onclick="window.location.href='/events.html'">
                    Tickets
                </button>
                <div class="hidden md:flex items-center gap-4 ml-2">
                    <a href="https://www.youtube.com/c/MiguelCottoPromotions" target="_blank" class="text-white hover:text-primary transition-colors">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                    <a href="https://www.instagram.com/miguelcottopromotions/" target="_blank" class="text-white hover:text-primary transition-colors">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.981 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
                    </a>
                    <a href="https://www.facebook.com/miguelcottopromotions/" target="_blank" class="text-white hover:text-primary transition-colors">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow">
        {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="bg-surface py-20 border-t border-border-muted mt-auto">
        <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col items-center">
            <div class="flex items-center justify-center mb-10">
                <img src="/assets/logo.svg" alt="Miguel Cotto Promotions Logo" class="h-[69px] md:h-[92px] w-auto object-contain" />
            </div>
            <nav class="flex flex-wrap justify-center gap-x-12 gap-y-6 mb-12">
                <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase" href="/events.html">Events</a>
                <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase" href="/boxers.html">Boxers</a>
                <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase" href="/news.html">News</a>
                <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase" href="/#videos">Videos</a>
                <a class="text-xs font-bold tracking-widest hover:text-primary transition-colors uppercase" href="/about.html">About Us</a>
            </nav>
            <div class="flex gap-6 mb-12">
                <a href="https://www.youtube.com/c/MiguelCottoPromotions" target="_blank" class="w-10 h-10 rounded-full bg-border-muted flex items-center justify-center hover:bg-primary transition-colors text-white">
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
                <a href="https://www.instagram.com/miguelcottopromotions/" target="_blank" class="w-10 h-10 rounded-full bg-border-muted flex items-center justify-center hover:bg-primary transition-colors text-white">
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.981 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
                </a>
                <a href="https://www.facebook.com/miguelcottopromotions/" target="_blank" class="w-10 h-10 rounded-full bg-border-muted flex items-center justify-center hover:bg-primary transition-colors text-white">
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
            </div>
            <div class="text-center">
                <p class="text-slate-500 text-[10px] tracking-widest uppercase mb-2">© {{ page.date | date('YYYY') if page.date else '2024' }} Miguel Cotto Promotions. All rights reserved.</p>
                <div class="flex gap-4 justify-center text-[10px] tracking-widest uppercase font-bold text-slate-400">
                    <a class="hover:text-primary" href="/index.html">Privacy Policy</a>
                    <a class="hover:text-primary" href="/index.html">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    {% block scripts %}{% endblock %}
</body>
</html>
